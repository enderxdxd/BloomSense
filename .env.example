# BloomSense environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must never be committed.

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
# API key used by the quiz endpoint to call GPT-4o-mini.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------------------------------------------------------
# Database (Supabase PostgreSQL via Prisma)
# ---------------------------------------------------------------------------
# Get both from Supabase: Project Settings > Database > Connection string.
# DATABASE_URL uses the transaction pooler (port 6543) — used by the app at runtime.
# DIRECT_URL is the direct connection (port 5432) — used by Prisma migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Secret used to sign JWT session tokens. Generate with:
#   openssl rand -base64 32   (or any 32+ char random string)
NEXTAUTH_SECRET=your-random-32-char-secret-here
# Base URL of the app (no trailing slash). Use the production URL when deployed.
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Upstash Redis (rate limiting)
# ---------------------------------------------------------------------------
# Create a free Redis database at https://console.upstash.com and copy the
# REST credentials. When unset, the app falls back to an in-memory limiter
# (per-process — fine for local dev, NOT for production/serverless).
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ---------------------------------------------------------------------------
# Stripe (payments)
# ---------------------------------------------------------------------------
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
# The publishable key is the ONLY env var that may be exposed client-side.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# locally, or the webhook endpoint config in the Stripe dashboard in prod.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ---------------------------------------------------------------------------
# Supabase Storage (mood board persistence)
# ---------------------------------------------------------------------------
# Project Settings > API. The service-role key is server-only — NEVER expose
# it client-side. When unset, mood boards are returned as ephemeral data
# URIs and not persisted.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
